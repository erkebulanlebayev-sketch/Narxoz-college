# Supabase Configuration
# Получите эти значения из вашего Supabase проекта: Settings > API

# URL вашего Supabase проекта
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public ключ (безопасно использовать на клиенте)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role ключ (ТОЛЬКО для серверной стороны, НЕ публикуйте!)
# Этот ключ обходит RLS политики - используйте осторожно
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection String (опционально, для прямого подключения к БД)
# Формат: postgres://postgres:[YOUR-PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL=postgres://postgres:your-password@db.your-project-id.supabase.co:5432/postgres
